<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <include layout="@layout/menu_superior"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Destinos de Intercâmbio"
            style="@style/TextScreenTitle"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explore os melhores lugares para estudar"
            android:layout_marginBottom="12dp"
            style="@style/TextBodySecondary"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            style="@style/CardDefault">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/text_secondary"/>

                <EditText
                    android:id="@+id/barraPesquisa"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Pesquisar destino..."
                    android:paddingStart="10dp"
                    style="@style/EditTextSearch"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/text_secondary"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/botaoFiltroIdioma"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Idioma"
                android:textAllCaps="false"
                android:backgroundTint="@color/filter_chip_bg"
                android:textColor="@color/filter_chip_text"/>

            <Button
                android:id="@+id/botaoFiltroContinente"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Continente"
                android:textAllCaps="false"
                android:layout_marginStart="10dp"
                android:backgroundTint="@color/filter_chip_bg"
                android:textColor="@color/filter_chip_text"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destinos populares"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"
            style="@style/TextSectionTitle"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listaTodosDestinos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="90dp"/>

    </LinearLayout>

    <include layout="@layout/menu_inferior"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>