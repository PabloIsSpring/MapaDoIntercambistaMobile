<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Menu superior -->

    <include layout="@layout/menu_superior"/>

    <!-- Conteúdo -->

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Título -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Destinos de Intercâmbio"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explore os melhores lugares para estudar"
            android:textColor="#666"
            android:layout_marginBottom="12dp"/>


        <!-- Barra de pesquisa -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"/>

                <EditText
                    android:id="@+id/barraPesquisa"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Pesquisar destino..."
                    android:background="@null"
                    android:paddingStart="10dp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_filter"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- Filtros -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Idioma"
                android:textAllCaps="false"
                android:backgroundTint="#EEEEEE"
                android:textColor="#444"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Continente"
                android:textAllCaps="false"
                android:layout_marginStart="10dp"
                android:backgroundTint="#EEEEEE"
                android:textColor="#444"/>

        </LinearLayout>


        <!-- Título destinos -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destinos populares"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"/>


        <!-- Lista -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listaTodosDestinos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- Menu inferior -->

    <include layout="@layout/menu_inferior"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>