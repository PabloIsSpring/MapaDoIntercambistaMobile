<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#568FF9"
    android:padding="20dp">

    <!-- Botão voltar -->
    <ImageView
        android:id="@+id/botaoVoltarCadastro"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_arrow_left"
        app:tint="@android:color/white" />

    <!-- BLOCO CENTRAL (LOGO + TEXTO) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="300dp"
            android:layout_height="140dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"/>

        <!-- Texto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crie sua conta ✨"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastre-se para continuar"
            android:textColor="@android:color/white"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nome"
        android:textColor="@android:color/white"/>

    <EditText
        android:id="@+id/inputNomeCadastro"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Digite seu nome"
        android:background="@drawable/bg_input"
        android:padding="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- Email -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textColor="@android:color/white"/>

    <EditText
        android:id="@+id/inputEmailCadastro"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Digite seu email"
        android:background="@drawable/bg_input"
        android:padding="10dp"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="12dp"/>

    <!-- Senha -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Senha"
        android:textColor="@android:color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="10dp">

        <EditText
            android:id="@+id/inputSenhaCadastro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Digite sua senha"
            android:inputType="textPassword"
            android:padding="10dp"/>

        <ImageView
            android:id="@+id/iconeOlhoSenhaCadastro"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_eye"/>
    </LinearLayout>

    <!-- Confirmar Senha -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirme sua senha"
        android:textColor="@android:color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="10dp">

        <EditText
            android:id="@+id/inputConfirmarSenhaCadastro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Confirme sua senha"
            android:inputType="textPassword"
            android:padding="10dp"/>

        <ImageView
            android:id="@+id/iconeOlhoConfirmarSenhaCadastro"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_eye"/>
    </LinearLayout>
    <!-- Botão cadastrar -->
    <Button
        android:id="@+id/botaoCadastrar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Cadastrar-se"
        android:backgroundTint="#FFFFFF"
        android:textColor="#568FF9"/>

</LinearLayout>