<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <include layout="@layout/menu_superior"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/botaoVoltarRespostas"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="Voltar"
                android:layout_marginBottom="12dp"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Respostas"
                style="@style/TextScreenTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Veja as respostas desta publicação"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/fotoPerfilPostOriginal"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_user"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImageShape"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_light" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/nomeUsuarioPostOriginal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/textoBadgeVocePostOriginal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@color/color_primary_light"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:text="Você"
                            android:textColor="@color/color_accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tempoPostOriginal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/botaoOpcoesPostOriginal"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_more_vert"
                            android:visibility="gone"
                            app:tint="@color/text_muted" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/mensagemPostOriginal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="19sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:id="@+id/botaoLikePostOriginal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iconeLikePostOriginal"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_like"
                                app:tint="@color/green_like" />

                            <TextView
                                android:id="@+id/textoLikesPostOriginal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:text="0"
                                android:textColor="@color/green_like"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/botaoDislikePostOriginal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="22dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iconeDislikePostOriginal"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_dislike"
                                app:tint="@color/red_dislike" />

                            <TextView
                                android:id="@+id/textoDislikesPostOriginal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:text="0"
                                android:textColor="@color/red_dislike"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="22dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chat"
                                app:tint="@color/color_accent" />

                            <TextView
                                android:id="@+id/textoQuantidadeRespostasPostOriginal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:text="0 respostas"
                                android:textColor="@color/color_accent"
                                android:textSize="13sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color" />

        <LinearLayout
            android:id="@+id/cardResponder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iconeAvatarResponder"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_user"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/CircleImageShape"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/textoResponderBloqueado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Postar sua resposta"
                android:textColor="@color/text_muted"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botaoResponderAcao"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Responder"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                app:backgroundTint="@color/text_secondary"
                app:cornerRadius="22dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listaRespostas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="90dp" />

    </LinearLayout>

    <include layout="@layout/menu_inferior"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>