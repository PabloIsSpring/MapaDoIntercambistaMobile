<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- topo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/fotoPerfil"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_launcher_foreground" />

            <TextView
                android:id="@+id/nomeUsuario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textoTempoPostagem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="há 2h"
                android:textColor="#666666"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- mensagem -->
        <TextView
            android:id="@+id/textoMensagem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="15sp"
            android:textColor="#333333" />

        <!-- linha separadora -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#D9D9D9" />

        <!-- ações -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconeLike"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_like"
                app:tint="#4CAF50" />

            <TextView
                android:id="@+id/textoLikes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#4CAF50"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/iconeDislike"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_dislike"
                app:tint="#F44336" />

            <TextView
                android:id="@+id/textoDislikes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#F44336"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/botaoRespostas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iconeRespostas"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_chat"
                    app:tint="#3F51B5" />

                <TextView
                    android:id="@+id/textoRespostas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0 respostas"
                    android:textColor="#3F51B5"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>