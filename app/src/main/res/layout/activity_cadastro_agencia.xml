<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollCadastroAgencia"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_topbar_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <ImageView
            android:id="@+id/botaoVoltarCadastroAgencia"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/text_on_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="220dp"
                android:layout_height="96dp"
                android:adjustViewBounds="true"
                android:scaleType="fitStart"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Cadastre sua agência"
                android:textColor="@color/text_on_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.94"
                android:lineSpacingExtra="2dp"
                android:text="Crie a conta da sua agência para divulgar e gerenciar pacotes de intercâmbio."
                android:textColor="@color/text_on_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Criar conta de agência"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Preencha os dados obrigatórios da agência"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Razão social"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputRazaoSocialCadastroAgencia"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite a razão social"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:imeOptions="actionNext" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Nome fantasia"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputNomeFantasiaCadastroAgencia"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite o nome fantasia"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:imeOptions="actionNext" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="CNPJ"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputCnpjCadastroAgencia"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite o CNPJ"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:imeOptions="actionNext" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Username"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputUsernameCadastroAgencia"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Escolha o username da agência"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:imeOptions="actionNext" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="E-mail"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputEmailCadastroAgencia"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Digite o e-mail da agência"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:imeOptions="actionNext" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Senha"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/inputSenhaCadastroAgencia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Digite sua senha"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/iconeOlhoSenhaCadastroAgencia"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_eye"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Confirme sua senha"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/inputConfirmarSenhaCadastroAgencia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Confirme sua senha"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/iconeOlhoConfirmarSenhaCadastroAgencia"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_eye"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:text="A senha deve ter entre 8 e 32 caracteres, incluindo maiúscula, minúscula, número e símbolo."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/botaoCadastrarAgencia"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:text="Criar conta de agência"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/color_accent"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>