<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary">

    <include layout="@layout/menu_superior"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="84dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Cabeçalho -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:background="@color/background_primary">

            <TextView
                android:id="@+id/tituloForum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fórum"
                style="@style/TextScreenTitle" />

            <TextView
                android:id="@+id/subtituloForum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Explore as discussões da comunidade"
                style="@style/TextBodySecondary" />
        </LinearLayout>

        <!-- Busca e ação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:background="@color/background_primary">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/barraPesquisaForum"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Pesquisar publicações..."
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:paddingStart="10dp"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/iconeFiltroForum"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_filter"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/botaoNovoForum"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:text="Novo"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                app:backgroundTint="@color/color_accent"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_add_circle"
                app:iconTint="@color/text_on_primary"
                app:iconPadding="8dp" />

        </LinearLayout>

        <!-- Resultados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/textoResultadosForum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 resultados"
                style="@style/TextCaptionMuted" />
        </LinearLayout>

        <!-- Lista -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/background_secondary">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listaTodosForuns"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/containerVazioForum"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/text_muted" />

                <TextView
                    android:id="@+id/textoVazioForum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Nenhuma publicação encontrada"
                    android:textColor="@color/text_muted"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Tente outro termo de busca ou crie uma nova publicação"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <include layout="@layout/menu_inferior"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>