<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerResposta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/background_primary"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <View
        android:id="@+id/linhaThread"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="10dp"
        android:background="@color/thread_line"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/fotoPerfilResposta"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/ic_user"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleImageShape"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_light" />

    <LinearLayout
        android:id="@+id/blocoResposta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/nomeUsuarioResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/textoBadgeVoceResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@color/color_primary_light"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Você"
                android:textColor="@color/color_accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textoTempoResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/botaoOpcoesResposta"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_more_vert"
                android:visibility="gone"
                app:tint="@color/text_muted" />
        </LinearLayout>

        <TextView
            android:id="@+id/textoMensagemResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="17sp"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/botaoLikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconeLikeResposta"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_like"
                    app:tint="@color/green_like" />

                <TextView
                    android:id="@+id/textoLikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/green_like"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoDislikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconeDislikeResposta"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_dislike"
                    app:tint="@color/red_dislike" />

                <TextView
                    android:id="@+id/textoDislikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/red_dislike"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoResponderResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/color_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Responder"
                    android:textColor="@color/color_accent"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textoToggleRespostas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="Ver respostas"
                android:textColor="@color/color_accent"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="@color/divider_color" />

    </LinearLayout>

</LinearLayout>