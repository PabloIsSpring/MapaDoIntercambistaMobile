<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/containerResposta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Linha da thread -->
    <View
        android:id="@+id/linhaThread"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="10dp"
        android:background="#D6D6D6" />

    <!-- Conteúdo da resposta -->
    <LinearLayout
        android:id="@+id/blocoResposta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <!-- topo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/fotoPerfilResposta"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_launcher_foreground" />

            <TextView
                android:id="@+id/nomeUsuarioResposta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#222222" />

            <TextView
                android:id="@+id/textoTempoResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="há 1h"
                android:textColor="#777777"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- mensagem -->
        <TextView
            android:id="@+id/textoMensagemResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:textSize="14sp"
            android:textColor="#333333" />

        <!-- ações -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/botaoLikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconeLikeResposta"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_like"
                    app:tint="#4CAF50"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <TextView
                    android:id="@+id/textoLikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoDislikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconeDislikeResposta"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_dislike"
                    app:tint="#F44336"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <TextView
                    android:id="@+id/textoDislikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="#F44336"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoResponderResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chat"
                    app:tint="#3F51B5"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Responder"
                    android:textColor="#3F51B5"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textoToggleRespostas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver respostas"
                android:textColor="#2962FF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#E7E7E7" />

    </LinearLayout>

</LinearLayout>