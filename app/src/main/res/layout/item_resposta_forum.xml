<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerResposta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Linha do Comentário -->
    <View
        android:id="@+id/linhaThread"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="10dp"
        android:background="#D7E1E8" />

    <!-- Fot de Perfil -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/fotoPerfilResposta"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/ic_user"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleImageShape"
        app:strokeWidth="1dp"
        app:strokeColor="#D9D9D9" />

    <!-- Conteúdo -->
    <LinearLayout
        android:id="@+id/blocoResposta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Topo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/nomeUsuarioResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/textoBadgeVoceResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="#E8F0FE"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Você"
                android:textColor="#2962FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textoTempoResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="#66757F"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/botaoOpcoesResposta"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_more_vert"
                android:visibility="gone"
                app:tint="#66757F" />
        </LinearLayout>

        <!-- Mensagem -->
        <TextView
            android:id="@+id/textoMensagemResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="17sp"
            android:textColor="#111111"
            android:lineSpacingExtra="2dp" />

        <!-- Ações -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/botaoLikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconeLikeResposta"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_like"
                    app:tint="#4CAF50" />

                <TextView
                    android:id="@+id/textoLikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="#4CAF50"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoDislikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconeDislikeResposta"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_dislike"
                    app:tint="#F44336" />

                <TextView
                    android:id="@+id/textoDislikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="#F44336"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoResponderResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/ic_chat"
                    app:tint="#3F51B5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Responder"
                    android:textColor="#3F51B5"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textoToggleRespostas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="Ver respostas"
                android:textColor="#2962FF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#E6ECF0" />

    </LinearLayout>

</LinearLayout>