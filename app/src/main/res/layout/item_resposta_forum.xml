<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerResposta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/background_secondary"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <View
        android:id="@+id/linhaThread"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp"
        android:background="@color/thread_line" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/fotoPerfilResposta"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_user"
        app:shapeAppearanceOverlay="@style/CircleImageShape"
        app:strokeColor="@color/border_light"
        app:strokeWidth="1dp" />

    <LinearLayout
        android:id="@+id/blocoResposta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/nomeUsuarioResposta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textoBadgeVoceResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_voce"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Você"
                android:textColor="@color/color_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textoTempoResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:maxLines="1"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/botaoOpcoesResposta"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_more_vert"
                android:visibility="gone"
                app:tint="@color/text_muted" />
        </LinearLayout>

        <TextView
            android:id="@+id/textoMensagemResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/linhaAcoesResposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/botaoLikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="30dp"
                android:orientation="horizontal"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/iconeLikeResposta"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_like"
                    app:tint="@color/green_like" />

                <TextView
                    android:id="@+id/textoLikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/green_like"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoDislikeResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="30dp"
                android:orientation="horizontal"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/iconeDislikeResposta"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_dislike"
                    app:tint="@color/red_dislike" />

                <TextView
                    android:id="@+id/textoDislikesResposta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0"
                    android:textColor="@color/red_dislike"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoResponderResposta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="30dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/color_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Responder"
                    android:textColor="@color/color_accent"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textoToggleRespostas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="26dp"
            android:gravity="center_vertical"
            android:text="Ver respostas"
            android:textColor="@color/color_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/divider_color"
            android:alpha="0.55" />

    </LinearLayout>

</LinearLayout>