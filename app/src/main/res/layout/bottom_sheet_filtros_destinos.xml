<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtros"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Refine os destinos exibidos"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Idioma"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <Spinner
        android:id="@+id/spinnerFiltroIdioma"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Continente"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <Spinner
        android:id="@+id/spinnerFiltroContinente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="País"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <Spinner
        android:id="@+id/spinnerFiltroPais"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Ordenação"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <Spinner
        android:id="@+id/spinnerFiltroOrdenacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <CheckBox
        android:id="@+id/checkSomenteFavoritos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Mostrar só favoritos"
        android:textColor="@color/text_primary"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoLimparFiltrosBottomSheet"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Limpar"
            android:textAllCaps="false"
            android:textColor="@color/color_accent"
            app:backgroundTint="@color/color_primary_light"
            app:cornerRadius="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoAplicarFiltrosBottomSheet"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:text="Aplicar"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary"
            app:backgroundTint="@color/color_accent"
            app:cornerRadius="14dp"/>

    </LinearLayout>

</LinearLayout>