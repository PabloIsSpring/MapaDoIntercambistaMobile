<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imagemBanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.58"
        android:background="@color/overlay_dark_soft" />

    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <TextView
            android:id="@+id/tituloBanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="1dp"
            android:text="Seu próximo intercâmbio começa aqui"
            android:textColor="@color/text_on_primary"
            android:textSize="23sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtituloBanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.95"
            android:text="Descubra programas, destinos e agências confiáveis para viver sua próxima experiência internacional."
            android:textColor="@color/text_on_primary"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>