<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- IMAGEM DO BANNER -->
    <ImageView
        android:id="@+id/imagemBanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- CONTEÚDO SOBRE A IMAGEM -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_gravity="start|center_vertical"
        android:padding="20dp"
        android:layout_width="250dp"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tituloBanner"
            android:text="PROGRAMAS DE INTERCÂMBIO"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/subtituloBanner"
            android:text="Confira já os nossos planos de viagens"
            android:textColor="#DDFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/botaoBanner"
            android:text="Confira já"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"
            android:backgroundTint="#2F2DCE"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</FrameLayout>