<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imagemBanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark_soft" />

    <LinearLayout
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <TextView
            android:id="@+id/tituloBanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROGRAMAS DE INTERCÂMBIO"
            android:textColor="@color/text_on_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtituloBanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Confira já os nossos planos de viagens"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp"
            android:alpha="0.92" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoBanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Explorar"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary"
            android:textStyle="bold"
            app:backgroundTint="@color/color_accent"
            app:cornerRadius="16dp"
            app:elevation="2dp" />

    </LinearLayout>

</FrameLayout>