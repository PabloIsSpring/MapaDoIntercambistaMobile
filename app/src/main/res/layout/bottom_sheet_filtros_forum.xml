<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtros do fórum"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Escolha como deseja organizar as publicações"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"/>

    <RadioGroup
        android:id="@+id/radioGroupOrdenacaoForum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioRecentesForum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mais recentes"
            android:textColor="@color/text_primary"/>

        <RadioButton
            android:id="@+id/radioCurtidosForum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mais curtidos"
            android:textColor="@color/text_primary"/>

        <RadioButton
            android:id="@+id/radioRespondidosForum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mais respondidos"
            android:textColor="@color/text_primary"/>

    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoFecharFiltrosForum"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Fechar"
            android:textAllCaps="false"
            android:textColor="@color/color_accent"
            app:backgroundTint="@color/color_primary_light"
            app:cornerRadius="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoAplicarFiltrosForum"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:text="Aplicar"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary"
            app:backgroundTint="@color/color_accent"
            app:cornerRadius="14dp"/>

    </LinearLayout>

</LinearLayout>