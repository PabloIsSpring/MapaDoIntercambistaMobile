<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Bottom Navigation -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/BottomNavActiveIndicator</item>
    </style>

    <style name="BottomNavActiveIndicator">
        <item name="android:color">@color/color_primary_light</item>
        <item name="shapeAppearance">@style/ShapeAppearance.BottomNavActiveIndicator</item>
    </style>

    <style name="ShapeAppearance.BottomNavActiveIndicator" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Imagem circular -->
    <style name="CircleImageShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Títulos -->
    <style name="TextScreenTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextSectionTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextCardTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextBodyPrimary">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextBodySecondary">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextCaptionMuted">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <style name="TextActionLink">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_accent</item>
    </style>

    <!-- Cards -->
    <style name="CardDefault">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="CardLarge">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- Campo de busca -->
    <style name="EditTextSearch">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:background">@null</item>
    </style>

</resources>